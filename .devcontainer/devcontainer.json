{
    "name": "ScyllaDB Integrated Dev",
    "dockerComposeFile": "docker-compose.yml",
    "service": "scylla-dev",
    "workspaceFolder": "/workspace",
    "shutdownAction": "none",
    "remoteUser": "${localEnv:USER:devuser}",
    "customizations": {
        "vscode": {
            "extensions": [
                "atlassian.atlascode",
                "eamodio.gitlens",
                "github.copilot-chat",
                "github.vscode-pull-request-github",
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-azuretools.vscode-docker",
                "ms-python.autopep8",
                "ms-python.black-formatter",
                "ms-python.flake8",
                "ms-python.pylint",
                "ms-python.python",
                "ms-vscode.cpptools"
            ]
        }
    }
}
